@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="register-container d-flex align-items-center justify-content-center py-5">
    <div class="register-card shadow-lg animate__animated animate__fadeInUp">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-center p-5 bg-dark text-white info-section">
                <div class="mb-4">
                    <span class="badge bg-primary px-3 py-2 rounded-pill mb-3">Join Us Today</span>
                    <h2 class="display-6 fw-bold">Start Your <span class="text-primary">Journey</span></h2>
                    <p class="opacity-75">আমাদের ইনভেন্টরি ম্যানেজমেন্ট সিস্টেমে যোগ দিয়ে আপনার ব্যবসাকে আরও স্মার্টভাবে পরিচালনা করুন।</p>
                </div>

                <div class="benefit-item d-flex align-items-center mb-3">
                    <div class="icon-circle me-3"><i class="fa fa-check"></i></div>
                    <span>সহজ ইনভেন্টরি ট্র্যাকিং</span>
                </div>
                <div class="benefit-item d-flex align-items-center mb-3">
                    <div class="icon-circle me-3"><i class="fa fa-check"></i></div>
                    <span>সুরক্ষিত কাস্টমার ডাটাবেজ</span>
                </div>
                <div class="benefit-item d-flex align-items-center mb-4">
                    <div class="icon-circle me-3"><i class="fa fa-check"></i></div>
                    <span>রিয়েল-টাইম রিপোর্ট জেনারেশন</span>
                </div>

                <div class="mt-auto text-center">
                    <img src="https://illustrations.popsy.co/white/work-from-home.svg" alt="Register" class="img-fluid opacity-50" style="max-height: 180px;">
                </div>
            </div>

            <div class="col-lg-7 bg-white p-4 p-md-5">
                <div class="mb-4 text-center text-lg-start">
                    <h3 class="fw-bold text-dark">Create Your Account</h3>
                    <p class="text-muted small">Please fill in the details to get started.</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Name" class="form-control border-0 bg-light rounded-3" autocomplete="Name" placeholder="John Doe" />
                                <label asp-for="Input.Name"><i class="fa fa-user me-2"></i>Full Name</label>
                                <span asp-validation-for="Input.Name" class="text-danger x-small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.CellPhone" class="form-control border-0 bg-light rounded-3" autocomplete="CellPhone" placeholder="017..." />
                                <label asp-for="Input.CellPhone"><i class="fa fa-phone me-2"></i>Cell Phone</label>
                                <span asp-validation-for="Input.CellPhone" class="text-danger x-small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Country" class="form-control border-0 bg-light rounded-3" autocomplete="Country" placeholder="Bangladesh" />
                                <label asp-for="Input.Country"><i class="fa fa-globe me-2"></i>Country</label>
                                <span asp-validation-for="Input.Country" class="text-danger x-small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control border-0 bg-light rounded-3" autocomplete="username" placeholder="name@example.com" />
                                <label asp-for="Input.Email"><i class="fa fa-envelope me-2"></i>Email Address</label>
                                <span asp-validation-for="Input.Email" class="text-danger x-small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control border-0 bg-light rounded-3" autocomplete="new-password" placeholder="password" />
                                <label asp-for="Input.Password"><i class="fa fa-key me-2"></i>Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger x-small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-4">
                                <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-light rounded-3" autocomplete="new-password" placeholder="password" />
                                <label asp-for="Input.ConfirmPassword"><i class="fa fa-shield-alt me-2"></i>Confirm</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger x-small"></span>
                            </div>
                        </div>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm transition-hover py-2 mb-4">
                        Complete Registration <i class="fa fa-arrow-right ms-2"></i>
                    </button>

                    <div class="text-center">
                        <p class="text-muted small">
                            Already have an account?
                            <a asp-page="./Login" class="text-primary fw-bold text-decoration-none border-bottom border-primary">Log in here</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: #f8f9fa;
        min-height: 100vh;
    }

    .register-container {
        min-height: 100vh;
    }

    .register-card {
        max-width: 1100px;
        width: 100%;
        background: #fff;
        border-radius: 30px;
        overflow: hidden;
        border: none;
    }

    .info-section {
        background: linear-gradient(135deg, #212529 0%, #343a40 100%) !important;
        position: relative;
    }

    .icon-circle {
        width: 30px;
        height: 30px;
        background: rgba(13, 110, 253, 0.2);
        color: #0d6efd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
    }

    .form-control {
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background-color: #fff !important;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.1);
            transform: translateY(-1px);
        }

    .transition-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.2) !important;
    }

    .x-small {
        font-size: 0.75rem;
    }

    @@media (max-width: 991px) {
        .register-card {
            margin: 20px;
            border-radius: 20px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="~/lib/animate.css/animate.min.css" rel="stylesheet" />
}