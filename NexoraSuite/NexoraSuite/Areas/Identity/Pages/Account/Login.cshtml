@page
@model LoginModel

@{
    ViewData["Title"] = "Secure Login";
}

<div class="login-container d-flex align-items-center justify-content-center">
    <div class="login-card row g-0 shadow-lg animate__animated animate__zoomIn">

        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center bg-primary text-white p-5 brand-section">
            <div class="brand-overlay"></div>
            <div class="position-relative text-center z-1">
                <i class="fas fa-user-shield fa-5x mb-4 opacity-75"></i>
                <h2 class="display-5 fw-bold">Welcome Back!</h2>
                @* <p class="lead opacity-75">আপনার ইনভেন্টরি ম্যানেজমেন্ট সিস্টেমকে আরও সুরক্ষিত রাখতে লগইন করুন।</p> *@

            </div>
        </div>

        <div class="col-lg-6 bg-white p-4 p-md-5 d-flex flex-column justify-content-center">
            <div class="text-center mb-4">
                <h3 class="fw-bold text-dark">Account Login</h3>
                <p class="text-muted small">Please enter your credentials below</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control border-0 bg-light rounded-3" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email"><i class="fa fa-envelope me-2"></i>Email Address</label>
                    <span asp-validation-for="Input.Email" class="text-danger x-small"></span>
                </div>

                <div class="form-floating mb-3 position-relative">
                    <input asp-for="Input.Password" id="passwordField" class="form-control border-0 bg-light rounded-3" autocomplete="current-password" placeholder="password" />
                    <label asp-for="Input.Password"><i class="fa fa-lock me-2"></i>Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger x-small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label small text-muted" asp-for="Input.RememberMe">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none fw-bold">Forgot?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm transition-hover py-2 mb-4">
                    Sign In <i class="fa fa-sign-in-alt ms-2"></i>
                </button>

                <div class="text-center">
                    <p class="text-muted small">
                        Don't have an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none">Register Now</a>
                    </p>
                    <hr class="my-4 opacity-25">
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted x-small text-decoration-none">Resend email confirmation</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .login-container {
        min-height: 90vh;
    }

    .login-card {
        max-width: 1000px;
        width: 100%;
        border-radius: 25px;
        overflow: hidden;
        border: none;
        background: #fff;
    }

    .brand-section {
        background: linear-gradient(135deg, #0d6efd 0%, #003d99 100%) !important;
        position: relative;
    }

    .brand-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.1;
    }

    .form-control {
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background-color: #fff !important;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.1);
            transform: translateY(-2px);
        }

    .transition-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.2) !important;
    }

    .z-1 {
        z-index: 1;
    }

    .x-small {
        font-size: 0.75rem;
    }

    @@media (max-width: 768px) {
        .login-card {
            margin: 15px;
            border-radius: 20px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="~/lib/animate.css/animate.min.css" rel="stylesheet" />
}