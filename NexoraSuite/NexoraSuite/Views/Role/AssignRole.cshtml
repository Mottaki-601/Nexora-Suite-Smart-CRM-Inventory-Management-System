@{
    ViewData["Title"] = "Assign Permission";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg p-4" style="border-radius: 24px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">

                <div class="text-center mb-4">
                    <div class="icon-box mb-3 mx-auto d-flex align-items-center justify-content-center"
                         style="width: 70px; height: 70px; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); border-radius: 20px; color: white; font-size: 30px;">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Assign Role</h2>
                    <p class="text-muted">Manage user permissions and access levels</p>
                </div>

                @if (ViewBag.msg != null)
                {
                    <div class="alert alert-success border-0 shadow-sm rounded-3 d-flex align-items-center mb-4" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        <div>@ViewBag.msg</div>
                    </div>
                }

                <form asp-action="AssignRole" asp-controller="Role" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-600 text-secondary ps-2"><i class="fa-solid fa-user-tag me-1"></i> Select User</label>
                        <div class="input-group shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="fa-solid fa-envelope text-primary"></i></span>
                            <select name="userData" class="form-select border-start-0 py-2 rounded-end-3" required>
                                <option value="" disabled selected>Choose a user...</option>
                                @foreach (var item in ViewBag.users)
                                {
                                    <option value="@item.Email">@item.Email</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-600 text-secondary ps-2"><i class="fa-solid fa-key me-1"></i> Select Role</label>
                        <div class="input-group shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="fa-solid fa-fingerprint text-purple" style="color:#a855f7"></i></span>
                            <select name="roleData" class="form-select border-start-0 py-2 rounded-end-3" required>
                                <option value="" disabled selected>Choose a role...</option>
                                @foreach (var item in ViewBag.roles)
                                {
                                    <option value="@item.NormalizedName">@item.NormalizedName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-lg border-0"
                            style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); border-radius: 15px; transition: all 0.3s ease;">
                        <i class="fa-solid fa-paper-plane me-2"></i> Confirm Assignment
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a asp-action="Index" class="text-decoration-none text-muted small">
                        <i class="fa-solid fa-arrow-left"></i> Back to Role List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-600 {
        font-weight: 600;
    }

    .form-select:focus {
        border-color: #6366f1;
        box-shadow: none;
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.4);
        opacity: 0.9;
    }
</style>