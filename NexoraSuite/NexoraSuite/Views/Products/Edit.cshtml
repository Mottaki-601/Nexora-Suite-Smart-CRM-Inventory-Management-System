@model NexoraSuite.Models.Product

@{
    ViewData["Title"] = "Update Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg overflow-hidden shadow-hover" style="border-radius: 30px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">

                <div style="height: 6px; background: linear-gradient(90deg, #0dcaf0 0%, #007bff 100%);"></div>

                <div class="card-body p-5">
                    <div class="row align-items-center mb-5">
                        <div class="col-auto">
                            <div class="icon-box bg-info text-white shadow-lg d-flex align-items-center justify-content-center"
                                 style="width: 65px; height: 65px; border-radius: 20px; font-size: 28px;">
                                <i class="fas fa-pen-to-square"></i>
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="fw-bold text-dark mb-0">Modify Entity</h2>
                            <p class="text-muted mb-0">Updating: <span class="text-info fw-bold">@Model.Name</span> (ID: #@Model.ProductId)</p>
                        </div>
                    </div>

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="ProductId" />

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="Name" class="form-control border-0 bg-light rounded-4 px-4" placeholder="Name" required style="height: 70px; font-size: 1.1rem;" />
                                    <label class="text-muted px-4"><i class="fas fa-box-open me-2"></i>Product Name</label>
                                </div>
                                <span asp-validation-for="Name" class="text-danger small ps-3"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <select asp-for="Category" class="form-select border-0 bg-light rounded-4 px-4" style="height: 70px;">
                                        <option value="" disabled>Select Category</option>
                                        <option value="Electronics">Electronics 📱</option>
                                        <option value="Clothing">Clothing 👕</option>
                                        <option value="Groceries">Groceries 🍏</option>
                                    </select>
                                    <label class="text-muted px-4"><i class="fas fa-tags me-2"></i>Category</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating shadow-sm">
                                    <input asp-for="SKU" class="form-control border-0 bg-light rounded-4 px-4" placeholder="SKU" style="height: 70px;" />
                                    <label class="text-muted px-4"><i class="fas fa-hashtag me-2"></i>SKU / Serial Code</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="input-group shadow-sm rounded-4 overflow-hidden">
                                    <span class="input-group-text border-0 bg-info text-white px-4 fs-5 fw-bold">৳</span>
                                    <div class="form-floating flex-grow-1">
                                        <input asp-for="Price" type="number" step="0.01" class="form-control border-0 bg-light py-4" placeholder="Price" required />
                                        <label class="text-muted">Unit Price (BDT)</label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="input-group shadow-sm rounded-4 overflow-hidden">
                                    <span class="input-group-text border-0 bg-dark text-white px-4 fs-5"><i class="fas fa-warehouse"></i></span>
                                    <div class="form-floating flex-grow-1">
                                        <input asp-for="Stock" type="number" class="form-control border-0 bg-light py-4" placeholder="Stock" />
                                        <label class="text-muted">Available Stock</label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-floating shadow-sm">
                                    <textarea asp-for="Description" class="form-control border-0 bg-light rounded-4 px-4 pt-4" placeholder="Description" style="height: 130px;"></textarea>
                                    <label class="text-muted px-4"><i class="fas fa-info-circle me-2"></i>Description & Specifications</label>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-5 pt-4 border-top g-3">
                            <div class="col-md-4 order-2 order-md-1">
                                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-3 rounded-4 fw-bold border-2 transition-hover">
                                    <i class="fas fa-times me-2"></i>Cancel Edit
                                </a>
                            </div>
                            <div class="col-md-8 order-1 order-md-2">
                                <button type="submit" class="btn btn-info text-white w-100 py-3 rounded-4 fw-bold shadow-lg border-0 transition-hover"
                                        style="background: linear-gradient(135deg, #0dcaf0 0%, #007bff 100%);">
                                    <i class="fas fa-sync-alt me-2"></i>Apply Changes & Save
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .rounded-4 {
        border-radius: 18px !important;
    }

    .form-control:focus, .form-select:focus {
        background-color: #ffffff !important;
        box-shadow: 0 0 0 4px rgba(13, 202, 240, 0.15) !important;
        color: #333;
    }

    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 20px rgba(0, 123, 255, 0.2) !important;
            filter: brightness(1.05);
        }

    .icon-box {
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    .input-group-text {
        min-width: 65px;
        justify-content: center;
    }

    .shadow-hover {
        transition: box-shadow 0.3s ease-in-out;
    }

        .shadow-hover:hover {
            box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}