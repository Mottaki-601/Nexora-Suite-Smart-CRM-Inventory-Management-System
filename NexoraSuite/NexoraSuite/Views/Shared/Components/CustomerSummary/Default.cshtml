<div class="card bg-light mb-3">
    <div class="card-header font-weight-bold">Database Summary</div>
    <div class="card-body">
        <p class="card-text">Total Customers: <strong>@ViewBag.TotalCount</strong></p>
        <p class="card-text">Total Credit Exposure: <strong>@ViewBag.TotalCredit?.ToString("C")</strong></p>
    </div>
</div>